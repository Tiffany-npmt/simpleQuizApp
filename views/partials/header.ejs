<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="header">

        <a class="logo" href="/">
            Quiz App
        </a>
        <div class="menu">

            <% if(user){ %>

                <span style="color:white;">
                    Hello <%= user.username %>
                </span>

                <a href="/logout" class="logout" style="color: tomato;">
                    Logout
                </a>

                <% } else { %>
                    <a href="/login" class="login">
                        Login
                    </a>

                    <a href="/register" class="register">
                        Register
                    </a>
                    <% } %>

        </div>

    </div>

</body>

</html>